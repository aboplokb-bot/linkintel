# === LINKINTEL ENVIRONMENT VARIABLES ===
# Copy this to .env.local and fill in your values

# OpenAI API Key (used for Whisper transcription + GPT-4 insights)
OPENAI_API_KEY=sk-...

# Optional: Max file size in MB before rejecting (default: 500)
MAX_FILE_SIZE_MB=500

# Optional: Temp directory for audio processing (default: /tmp)
TEMP_DIR=/tmp

# Optional: Override transcription provider (whisper | deepgram | assembly)
TRANSCRIPTION_PROVIDER=whisper
